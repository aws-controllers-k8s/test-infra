#!/usr/bin/env bash
#
# Generates a personal Terraform variable file for bootstrapping.
# Prompts for each variable with its default value.
# Output: bootstrap/environment/dev.tfvars
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_DIR="${SCRIPT_DIR}/environment"

mkdir -p "$ENV_DIR"

echo "=== ACK Test Infra - Terraform Environment Generator ==="
echo ""
echo "This will create environment/dev.tfvars with your personal settings."
echo "Press Enter to accept the default value shown in brackets."
echo ""

# Prompt helper: prompt <var_name> <description> <default>
prompt() {
  local var_name="$1"
  local description="$2"
  local default="$3"
  local value

  read -rp "  ${description} [${default}]: " value
  echo "${var_name} = \"${value:-$default}\""
}

echo "Configure variables:"
echo ""

# Collect variable values
vars=()
vars+=("$(prompt "region" "AWS region" "us-west-2")")
vars+=("$(prompt "account_id" "AWS account ID" "453735116143")")
vars+=("$(prompt "flux_version" "Flux chart version" "2.18.3")")
vars+=("$(prompt "test_infra_org" "GitHub org for test-infra repo" "aws-controllers-k8s")")
vars+=("$(prompt "test_infra_repo" "GitHub repo name for test-infra" "test-infra")")
vars+=("$(prompt "test_infra_branch" "Git branch for Flux and Prow jobs" "main")")
vars+=("$(prompt "stage" "Deployment stage (prod, staging, dev)" "prod")")
vars+=("$(prompt "prow_domain" "Domain for Prow Deck UI" "prow-staging.ack.aws.dev")")

# Write tfvars file
OUTPUT_FILE="${ENV_DIR}/dev.tfvars"

{
  echo "# Generated by gen-terraform-env on $(date -u +%Y-%m-%dT%H:%M:%SZ)"
  echo ""
  for var in "${vars[@]}"; do
    echo "$var"
  done
} > "$OUTPUT_FILE"

echo ""
echo "Written to: bootstrap/environment/dev.tfvars"
echo ""
echo "Usage:"
echo "  terraform init"
echo "  terraform plan  -var-file=environment/dev.tfvars"
echo "  terraform apply -var-file=environment/dev.tfvars"
